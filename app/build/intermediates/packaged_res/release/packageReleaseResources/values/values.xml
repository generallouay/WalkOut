<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="active_green">#1E8A3C</color>
    <color name="background">#FFFFFF</color>
    <color name="ic_launcher_background">#1A73E8</color>
    <color name="label">#333333</color>
    <color name="primary">#1A73E8</color>
    <color name="secondary_text">#888888</color>
    <color name="surface">#E8F0FE</color>
    <string name="app_name">WalkOut</string>
    <style name="InputField">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:background">@drawable/input_background</item>
    </style>
    <style name="LabelText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/label</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">4dp</item>
    </style>
    <style name="Theme.WalkOut" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary</item>
        <item name="colorOnPrimary">@android:color/white</item>
    </style>
</resources>